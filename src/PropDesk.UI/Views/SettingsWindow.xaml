<Window x:Class="PropDesk.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PropDesk – Settings"
        Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4C9BE8"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6272A4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="160"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#F1FA8C"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="BorderBrush" Value="#44475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="CaretBrush" Value="#F8F8F2"/>
        </Style>
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#F8F8F2"/>
            <Setter Property="BorderBrush" Value="#44475A"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="#50FA7B"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="*"/>     <!-- Form -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="⚙  Account Settings" FontFamily="Segoe UI" FontSize="20"
                       FontWeight="Bold" Foreground="#4C9BE8"/>
            <TextBlock Text="Configure your prop firm rules and account parameters"
                       FontFamily="Segoe UI" FontSize="11" Foreground="#6272A4" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Prop Firm -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="🏢  Prop Firm"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Prop Firm"/>
                    <ComboBox Style="{StaticResource ComboStyle}"
                              SelectedItem="{Binding PropFirm}">
                        <ComboBoxItem>MyFundedFutures</ComboBoxItem>
                        <ComboBoxItem>Apex Trader Funding</ComboBoxItem>
                        <ComboBoxItem>TopStep</ComboBoxItem>
                        <ComboBoxItem>TakeProfitTrader</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Account Name"/>
                    <TextBox Style="{StaticResource FieldBox}"
                             Text="{Binding AccountName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Account Type"/>
                    <ComboBox Style="{StaticResource ComboStyle}"
                              SelectedItem="{Binding AccountType}">
                        <ComboBoxItem>Evaluation</ComboBoxItem>
                        <ComboBoxItem>Sim Funded</ComboBoxItem>
                        <ComboBoxItem>Live Funded</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <!-- Account Financials -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="💰  Account Financials"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Account Size ($)"/>
                    <TextBox Style="{StaticResource FieldBox}"
                             Text="{Binding AccountSize, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Starting Balance ($)"/>
                    <TextBox Style="{StaticResource FieldBox}"
                             Text="{Binding StartingBalance, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Profit Target ($)"/>
                    <TextBox Style="{StaticResource FieldBox}"
                             Text="{Binding ProfitTarget, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Risk Rules -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="📉  Risk Rules"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Max Drawdown ($)"/>
                    <TextBox Style="{StaticResource FieldBox}"
                             Text="{Binding MaxDrawdown, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Daily Drawdown Limit ($)"/>
                    <TextBox Style="{StaticResource FieldBox}"
                             Text="{Binding DailyDrawdown, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Required Buffer ($)"/>
                    <TextBox Style="{StaticResource FieldBox}"
                             Text="{Binding RequiredBuffer, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Payout Rules -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="💸  Payout Rules"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Min Trading Days"/>
                    <TextBox Style="{StaticResource FieldBox}"
                             Text="{Binding MinTradingDays, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Consistency Limit (%)"/>
                    <TextBox Style="{StaticResource FieldBox}" Text="50" IsReadOnly="True"
                             Foreground="#6272A4"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="#44475A" Foreground="#F8F8F2"
                    FontFamily="Segoe UI" FontSize="12"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Style="{StaticResource SaveBtn}" Content="💾  Save Settings"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
</Window>