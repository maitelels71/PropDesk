<Window x:Class="PropDesk.UI.Views.PayoutHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PropDesk – Payout History"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="💸  Payout History" FontFamily="Segoe UI" FontSize="20"
                       FontWeight="Bold" Foreground="#50FA7B"/>
            <TextBlock Text="Every payout cycle stored permanently. Your trading record."
                       FontFamily="Segoe UI" FontSize="11" Foreground="#6272A4" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Summary Cards -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
            <Border Background="#2A2A3E" CornerRadius="8" Padding="16,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Cycles" FontFamily="Segoe UI" FontSize="10" Foreground="#6272A4"/>
                    <TextBlock Text="{Binding TotalCycles}" FontFamily="Segoe UI"
                               FontSize="22" FontWeight="Bold" Foreground="#F8F8F2"/>
                </StackPanel>
            </Border>
            <Border Background="#2A2A3E" CornerRadius="8" Padding="16,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Paid Out" FontFamily="Segoe UI" FontSize="10" Foreground="#6272A4"/>
                    <TextBlock Text="{Binding TotalPaid, StringFormat=${0:N2}}" FontFamily="Segoe UI"
                               FontSize="22" FontWeight="Bold" Foreground="#50FA7B"/>
                </StackPanel>
            </Border>
            <Border Background="#2A2A3E" CornerRadius="8" Padding="16,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Avg Per Cycle" FontFamily="Segoe UI" FontSize="10" Foreground="#6272A4"/>
                    <TextBlock Text="{Binding AvgPerCycle, StringFormat=${0:N2}}" FontFamily="Segoe UI"
                               FontSize="22" FontWeight="Bold" Foreground="#4C9BE8"/>
                </StackPanel>
            </Border>
            <Border Background="#2A2A3E" CornerRadius="8" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Best Cycle" FontFamily="Segoe UI" FontSize="10" Foreground="#6272A4"/>
                    <TextBlock Text="{Binding BestCycle, StringFormat=${0:N2}}" FontFamily="Segoe UI"
                               FontSize="22" FontWeight="Bold" Foreground="#F1FA8C"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- History Table -->
        <Border Grid.Row="2" Background="#2A2A3E" CornerRadius="8" Padding="4">
            <DataGrid ItemsSource="{Binding Cycles}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="#2A2A3E"
                      Foreground="#F8F8F2"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#3A3A5C"
                      RowBackground="#2A2A3E"
                      AlternatingRowBackground="#252535"
                      FontFamily="Segoe UI"
                      FontSize="12"
                      RowHeight="36"
                      CanUserSortColumns="True">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#12121E"/>
                        <Setter Property="Foreground" Value="#4C9BE8"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#2A2A3E"/>
                        <Setter Property="Foreground" Value="#F8F8F2"/>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"          Binding="{Binding Id}"                                   Width="40"/>
                    <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate, StringFormat=MM/dd/yyyy}"   Width="100"/>
                    <DataGridTextColumn Header="End Date"   Binding="{Binding EndDate, StringFormat=MM/dd/yyyy}"     Width="100"/>
                    <DataGridTextColumn Header="Net Profit" Binding="{Binding NetProfit, StringFormat=${0:N2}}"      Width="110"/>
                    <DataGridTextColumn Header="Largest Day"Binding="{Binding LargestWinDay, StringFormat=${0:N2}}"  Width="110"/>
                    <DataGridTextColumn Header="Consistency"Binding="{Binding ConsistencyPct, StringFormat={0:N2}%}" Width="100"/>
                    <DataGridTextColumn Header="Paid Out"   Binding="{Binding AmountPaid, StringFormat=${0:N2}}"     Width="110"/>
                    <DataGridTextColumn Header="Status"     Binding="{Binding Status}"                               Width="90"/>
                    <DataGridTextColumn Header="Notes"      Binding="{Binding Notes}"                                Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="📄  Export PDF" Margin="0,0,8,0"
                    Command="{Binding ExportPdfCommand}"
                    Background="#FF5555" Foreground="#F8F8F2"
                    FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                    Padding="16,8" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="✅  Close"
                    Click="Close_Click"
                    Background="#50FA7B" Foreground="#1E1E2E"
                    FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                    Padding="16,8" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>