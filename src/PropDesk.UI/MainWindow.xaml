<Window x:Class="PropDesk.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PropDesk.UI.Views"
        Title="PropDesk – Funded Futures Dashboard"
        Height="860" Width="1300" MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6272A4"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#F8F8F2"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#4C9BE8"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#12121E">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="PropDesk" FontFamily="Segoe UI" FontSize="20"
                                   FontWeight="Bold" Foreground="#4C9BE8"/>
                        <TextBlock Text="{Binding StatusMessage}" FontFamily="Segoe UI"
                                   FontSize="11" Foreground="#6272A4"/>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Background="#2A2A3E" CornerRadius="6" Padding="16,8" Margin="0,0,12,0">
                    <TextBlock Text="{Binding TrafficLightText}" FontFamily="Segoe UI"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{Binding TrafficLightColor}" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="2" Background="#2A2A3E" CornerRadius="6" Padding="12,8">
                    <TextBlock Text="MyFundedFutures" FontFamily="Segoe UI" FontSize="11"
                               Foreground="#6272A4" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT: Left metrics + Right chart -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1.8*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="6,6,0,6">
                    <!-- Key metrics -->
                    <UniformGrid Columns="5">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardLabel}" Text="Balance"/>
                                <TextBlock Style="{StaticResource CardValue}"
                                           Text="{Binding CurrentBalance, StringFormat=${0:N0}}"
                                           Foreground="#50FA7B"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardLabel}" Text="Net Profit"/>
                                <TextBlock Style="{StaticResource CardValue}"
                                           Text="{Binding NetProfit, StringFormat=${0:N2}}"
                                           Foreground="{Binding NetProfitColor}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardLabel}" Text="Largest Day"/>
                                <TextBlock Style="{StaticResource CardValue}"
                                           Text="{Binding LargestWinDay, StringFormat=${0:N2}}"
                                           Foreground="#F1FA8C"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardLabel}" Text="Days"/>
                                <TextBlock Style="{StaticResource CardValue}" Text="{Binding TradingDays}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardLabel}" Text="Buffer"/>
                                <TextBlock Style="{StaticResource CardValue}"
                                           Text="{Binding Buffer, StringFormat=${0:N0}}"
                                           Foreground="{Binding BufferColor}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Consistency + Payout -->
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="🎯  Consistency Rule" FontFamily="Segoe UI"
                                           FontSize="12" FontWeight="Bold" Foreground="#4C9BE8" Margin="0,0,0,10"/>
                                <TextBlock FontFamily="Segoe UI" FontSize="36" FontWeight="Bold"
                                           Text="{Binding ConsistencyPercent, StringFormat={0:N2}%}"
                                           Foreground="{Binding ConsistencyColor}" HorizontalAlignment="Center"/>
                                <ProgressBar Value="{Binding ConsistencyProgress}" Maximum="100"
                                             Height="8" Margin="0,8,0,10"
                                             Foreground="{Binding ConsistencyColor}" Background="#12121E"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CardLabel}" Text="Still needed"/>
                                        <TextBlock FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                                                   Text="{Binding RemainingProfit, StringFormat=${0:N2}}"
                                                   Foreground="#F1FA8C"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Style="{StaticResource CardLabel}" Text="Safe today"/>
                                        <TextBlock FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                                                   Text="{Binding MaxSafeToday, StringFormat=${0:N2}}"
                                                   Foreground="#50FA7B"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="💰  Payout Status" FontFamily="Segoe UI"
                                           FontSize="12" FontWeight="Bold" Foreground="#50FA7B" Margin="0,0,0,10"/>
                                <Border Background="{Binding EligibilityBg}" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding EligibilityText}" FontFamily="Segoe UI"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="{Binding EligibilityColor}"
                                               HorizontalAlignment="Center" TextWrapping="Wrap"/>
                                </Border>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CardLabel}" Text="Profit target"/>
                                        <TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                                                   Text="{Binding ProfitTargetMet}" Foreground="#50FA7B"/>
                                        <TextBlock Style="{StaticResource CardLabel}" Text="Min days" Margin="0,6,0,4"/>
                                        <TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                                                   Text="{Binding MinDaysMet}" Foreground="#50FA7B"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Style="{StaticResource CardLabel}" Text="Buffer"/>
                                        <TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                                                   Text="{Binding BufferMet}" Foreground="#50FA7B"/>
                                        <TextBlock Style="{StaticResource CardLabel}" Text="Max withdraw" Margin="0,6,0,4"/>
                                        <TextBlock FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                                                   Text="{Binding MaxWithdrawable, StringFormat=${0:N2}}"
                                                   Foreground="#F1FA8C"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Stats row -->
                    <UniformGrid Columns="3">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="📊 Performance" FontFamily="Segoe UI" FontSize="11"
                                           FontWeight="Bold" Foreground="#4C9BE8" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding PerformanceStats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}" FontFamily="Segoe UI" FontSize="11" Foreground="#6272A4"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="#F8F8F2"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="📉 Drawdown" FontFamily="Segoe UI" FontSize="11"
                                           FontWeight="Bold" Foreground="#FF5555" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding DrawdownStats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}" FontFamily="Segoe UI" FontSize="11" Foreground="#6272A4"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="#FF5555"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="📅 This Cycle" FontFamily="Segoe UI" FontSize="11"
                                           FontWeight="Bold" Foreground="#50FA7B" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding CycleStats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}" FontFamily="Segoe UI" FontSize="11" Foreground="#6272A4"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="#F8F8F2"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT: Charts -->
            <Border Grid.Column="1" Background="#2A2A3E" CornerRadius="8" Margin="6">
                <views:EquityChartView DataContext="{Binding ChartVM}"/>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="#12121E">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Style="{StaticResource ActionBtn}" Content="📂 Import CSV"
                        Command="{Binding ImportCsvCommand}"/>
                <Button Style="{StaticResource ActionBtn}" Content="💸 Payout History"
                        Command="{Binding OpenPayoutHistoryCommand}"
                        Background="#50FA7B" Foreground="#1E1E2E"/>
                <Button Style="{StaticResource ActionBtn}" Content="📄 Export Report"
                        Command="{Binding ExportReportCommand}"
                        Background="#FF5555" Foreground="#F8F8F2"/>
                <Button Style="{StaticResource ActionBtn}" Content="🔄 New Cycle"
                        Command="{Binding NewPayoutCycleCommand}"
                        Background="#F1FA8C" Foreground="#1E1E2E"/>
                <Button Style="{StaticResource ActionBtn}" Content="⚙ Settings"
                        Command="{Binding OpenSettingsCommand}"
                        Background="#44475A" Foreground="#F8F8F2"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>